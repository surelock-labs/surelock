{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@surelock-labs/router": ["packages/router/src"],
      "@surelock-labs/bundler": ["packages/bundler/src"]
    }
  },
  "include": [
    "scripts/**/*",
    "packages/**/*"
  ],
  "exclude": [
    "node_modules",
    "test",
    "typechain-types",
    "dist",
    "packages/*/dist"
  ]
}
